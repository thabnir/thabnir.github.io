---
export interface Props {
  id?: string;
  class?: string;
  // Boid count
  nBoids?: number;
  // Boid count for mobile?
  nBoidsMobile?: number;
  // Behavior
  visualRange?: number;
  minDistance?: number;
  maxSpeed?: number;
  minSpeed?: number;
  maxTurnRate?: number;
  fieldOfView?: number;
  alignmentFactor?: number;
  cohesionFactor?: number;
  separationFactor?: number;
  wallMargin?: number;
  wallTurnFactor?: number;
  // Cursor magnetism
  cursorMagnetism?: number;
  cursorMagnetismRange?: number;
  // Rendering
  boidSize?: number;
  trailLength?: number;
  drawTrail?: boolean;
  showVision?: boolean;
  showVisionCone?: boolean;
  visionBoidIndex?: number;
  // Camera
  followBoid?: boolean;
  zoomLevel?: number;
  cameraSmoothing?: number;
  zoomSmoothing?: number;
  // Colors
  colorMode?: "uniform" | "random" | "velocity" | "flock";
  uniformHue?: number;
  colorBlendSpeed?: number;
  // Performance
  fpsLimit?: number;
  enableFpsLimit?: boolean;
  showStats?: boolean;
  // Control panel
  showControls?: boolean;
  // Scroll automation
  enableScrollControl?: boolean;
}

const {
  id = "boids-canvas",
  class: className = "",
  nBoids = 800,
  visualRange = 30,
  minDistance = 10,
  maxSpeed = 1.5,
  minSpeed = 1.0,
  maxTurnRate = 0.07,
  fieldOfView = 230,
  alignmentFactor = 0.03,
  cohesionFactor = 0.0005,
  separationFactor = 0.0035,
  wallMargin = 30,
  wallTurnFactor = 0.45,
  cursorMagnetism = 0,
  cursorMagnetismRange = 200,
  boidSize = 10,
  trailLength = 40,
  drawTrail = true,
  showVision = false,
  showVisionCone = true,
  visionBoidIndex = 0,
  followBoid = false,
  zoomLevel = 1.0,
  cameraSmoothing = 0.1,
  zoomSmoothing = 0.05,
  colorMode = "velocity",
  uniformHue = 220,
  colorBlendSpeed = 0.05,
  fpsLimit = 60,
  enableFpsLimit = true,
  showStats = false,
  showControls = false,
  enableScrollControl = false,
  nBoidsMobile,
} = Astro.props;

const containerId = `${id}-container`;
const canvasId = id;
const controlsId = `${id}-controls`;
const toggleBtnId = `${id}-toggle`;
---

<div
  id={containerId}
  class:list={["boids-container", className]}
  data-boids-config={JSON.stringify({
    nBoids,
    visualRange,
    minDistance,
    maxSpeed,
    minSpeed,
    maxTurnRate,
    fieldOfView,
    alignmentFactor,
    cohesionFactor,
    separationFactor,
    wallMargin,
    wallTurnFactor,
    cursorMagnetism,
    cursorMagnetismRange,
    boidSize,
    trailLength,
    drawTrail,
    showVision,
    showVisionCone,
    visionBoidIndex,
    followBoid,
    zoomLevel,
    cameraSmoothing,
    zoomSmoothing,
    colorMode,
    uniformHue,
    colorBlendSpeed,
    fpsLimit,
    enableFpsLimit,
    showStats,
    showControls,
    enableScrollControl,
    nBoidsMobile,
  })}
>
  <canvas id={canvasId}></canvas>

  {
    showControls && (
      <>
        <button id={toggleBtnId} class="boids-toggle-btn" aria-label="Toggle controls">
          <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor">
            <path d="M120-240v-80h720v80H120Zm0-200v-80h720v80H120Zm0-200v-80h720v80H120Z" />
          </svg>
          <svg
            class="icon-close"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 -960 960 960"
            fill="currentColor"
            style="display: none;"
          >
            <path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z" />
          </svg>
        </button>
        <div id={controlsId} class="boids-controls collapsed">
          <h3>Boids Controls</h3>

          <div class="control-section">
            <h4>Simulation</h4>
            <div class="control-row">
              <button class="pause-btn">
                <svg class="icon-pause" xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor">
                  <path d="M560-200v-560h160v560H560Zm-320 0v-560h160v560H240Z" />
                </svg>
                <svg
                  class="icon-play"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  style="display: none;"
                >
                  <path d="M320-200v-560l440 280-440 280Z" />
                </svg>
                <span class="btn-text">Pause</span>
              </button>
              <button class="reset-btn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor">
                  <path d="M480-160q-134 0-227-93t-93-227q0-134 93-227t227-93q69 0 132 28.5T720-690v-110h80v280H520v-80h168q-32-56-87.5-88T480-720q-100 0-170 70t-70 170q0 100 70 170t170 70q77 0 139-44t87-116h84q-28 106-114 173t-196 67Z" />
                </svg>
                <span class="btn-text">Reset</span>
              </button>
            </div>
            <label>
              Boid Count: <span class="boid-count-value">{nBoids}</span>
              <input type="range" class="boid-count" min="10" max="10000" step="10" value={nBoids} />
              <small>(reset required)</small>
            </label>
          </div>

          <div class="control-section">
            <h4>Behavior</h4>
            <label>
              Visual Range: <span class="visual-range-value">{visualRange}</span>
              <input type="range" class="visual-range" min="10" max="200" step="5" value={visualRange} />
            </label>
            <label>
              Min Distance: <span class="min-distance-value">{minDistance}</span>
              <input type="range" class="min-distance" min="5" max="100" step="1" value={minDistance} />
            </label>
            <label>
              Max Speed: <span class="max-speed-value">{maxSpeed}</span>
              <input type="range" class="max-speed" min="1" max="5" step="0.1" value={maxSpeed} />
            </label>
            <label>
              Alignment: <span class="alignment-value">{alignmentFactor}</span>
              <input type="range" class="alignment" min="0" max="0.05" step="0.001" value={alignmentFactor} />
            </label>
            <label>
              Cohesion: <span class="cohesion-value">{cohesionFactor}</span>
              <input type="range" class="cohesion" min="0" max="0.05" step="0.0005" value={cohesionFactor} />
            </label>
            <label>
              Separation: <span class="separation-value">{separationFactor}</span>
              <input type="range" class="separation" min="0" max="0.05" step="0.001" value={separationFactor} />
            </label>
            <label>
              Wall Margin: <span class="wall-margin-value">{wallMargin}</span>
              <input type="range" class="wall-margin" min="20" max="300" step="10" value={wallMargin} />
            </label>
            <label>
              Wall Turn Factor: <span class="wall-turn-value">{wallTurnFactor}</span>
              <input type="range" class="wall-turn" min="0.05" max="1" step="0.05" value={wallTurnFactor} />
            </label>
          </div>

          <div class="control-section">
            <h4>Steering</h4>
            <label>
              Min Speed: <span class="min-speed-value">{minSpeed}</span>
              <input type="range" class="min-speed" min="0" max="5" step="0.1" value={minSpeed} />
            </label>
            <label>
              Max Turn Rate: <span class="max-turn-rate-value">{maxTurnRate}</span>
              <input type="range" class="max-turn-rate" min="0.01" max="1.0" step="0.01" value={maxTurnRate} />
              <small>Radians per frame</small>
            </label>
            <label>
              Field of View: <span class="fov-value">{fieldOfView}</span>&#176;
              <input type="range" class="fov" min="30" max="360" step="10" value={fieldOfView} />
            </label>
          </div>

          <div class="control-section">
            <h4>Cursor Magnetism</h4>
            <label>
              Strength: <span class="cursor-magnetism-value">{cursorMagnetism}</span>
              <input type="range" class="cursor-magnetism" min="-0.5" max="0.5" step="0.01" value={cursorMagnetism} />
              <small>Negative = repel</small>
            </label>
            <label>
              Range: <span class="magnetism-range-value">{cursorMagnetismRange}</span>
              <input type="range" class="magnetism-range" min="50" max="500" step="10" value={cursorMagnetismRange} />
            </label>
          </div>

          <div class="control-section">
            <h4>Colors</h4>
            <label>
              Color Mode:
              <select class="color-mode">
                <option value="uniform" selected={colorMode === "uniform"}>
                  Uniform
                </option>
                <option value="random" selected={colorMode === "random"}>
                  Random
                </option>
                <option value="velocity" selected={colorMode === "velocity"}>
                  Velocity
                </option>
                <option value="flock" selected={colorMode === "flock"}>
                  Flock Blend
                </option>
              </select>
            </label>
            <label class="uniform-hue-control" style={colorMode === "uniform" ? "" : "display: none;"}>
              Uniform Hue: <span class="uniform-hue-value">{uniformHue}</span>
              <input type="range" class="uniform-hue" min="0" max="360" step="1" value={uniformHue} />
            </label>
            <label class="blend-speed-control" style={colorMode === "flock" ? "" : "display: none;"}>
              Blend Speed: <span class="color-blend-speed-value">{colorBlendSpeed}</span>
              <input
                type="range"
                class="color-blend-speed"
                min="0.001"
                max="0.2"
                step="0.001"
                value={colorBlendSpeed}
              />
            </label>
          </div>

          <div class="control-section">
            <h4>Rendering</h4>
            <label>
              Boid Size: <span class="boid-size-value">{boidSize}</span>
              <input type="range" class="boid-size" min="3" max="30" step="1" value={boidSize} />
            </label>
            <label>
              Trail Length: <span class="trail-length-value">{trailLength}</span>
              <input type="range" class="trail-length" min="0" max="100" step="5" value={trailLength} />
            </label>
            <label class="checkbox-label">
              <input type="checkbox" class="draw-trail" checked={drawTrail} />
              Draw Trail
            </label>
            <label class="checkbox-label">
              <input type="checkbox" class="show-vision" checked={showVision} />
              Show Boid Vision
            </label>
            <label>
              Vision Boid Index: <span class="vision-boid-value">{visionBoidIndex}</span>
              <input type="range" class="vision-boid" min="0" max={nBoids - 1} step="1" value={visionBoidIndex} />
            </label>
          </div>

          <div class="control-section">
            <h4>Camera</h4>
            <label class="checkbox-label">
              <input type="checkbox" class="follow-boid" checked={followBoid} />
              Follow Selected Boid
            </label>
            <label>
              Zoom Level: <span class="zoom-level-value">{zoomLevel}</span>
              <input type="range" class="zoom-level" min="0.5" max="5" step="0.1" value={zoomLevel} />
            </label>
            <label>
              Camera Smoothing: <span class="camera-smoothing-value">{cameraSmoothing}</span>
              <input type="range" class="camera-smoothing" min="0.01" max="1.0" step="0.01" value={cameraSmoothing} />
            </label>
          </div>

          <div class="control-section">
            <h4>Performance</h4>
            <label class="checkbox-label">
              <input type="checkbox" class="show-stats" checked={showStats} />
              Show Stats
            </label>
            <label class="checkbox-label">
              <input type="checkbox" class="enable-fps-limit" checked={enableFpsLimit} />
              Enable FPS Limit
            </label>
            <label>
              FPS Limit: <span class="fps-limit-value">{fpsLimit}</span>
              <input type="range" class="fps-limit" min="10" max="144" step="1" value={fpsLimit} />
            </label>
          </div>
        </div>
      </>
    )
  }
</div>

<style>
  .boids-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .boids-container canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .boids-toggle-btn {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 1001;
    width: 36px;
    height: 36px;
    border: 1px solid var(--accent, rgba(255, 255, 255, 0.2));
    border-radius: 0;
    background: rgba(0, 0, 0, 0.8);
    color: #fff;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .boids-toggle-btn:hover {
    background: var(--accent, rgba(255, 255, 255, 0.1));
    border-color: var(--accent, rgba(255, 255, 255, 0.4));
    color: #fff;
  }

  .boids-controls {
    position: absolute;
    top: 16px;
    right: 60px;
    width: 320px;
    max-height: calc(100% - 32px);
    overflow-y: auto;
    overflow-x: hidden;
    background: rgba(0, 0, 0, 0.9);
    border: 1px solid var(--accent, rgba(255, 255, 255, 0.15));
    border-radius: 0;
    padding: 24px;
    box-sizing: border-box;
    z-index: 1000;
    color: #fff;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.5;
    transition:
      transform 0.15s ease,
      opacity 0.15s ease;
  }

  .boids-controls.collapsed {
    transform: translateX(400px);
    opacity: 0;
    pointer-events: none;
  }

  .boids-controls h3 {
    margin: 0 0 24px 0;
    font-size: 11px;
    font-weight: 700;
    color: var(--accent, #fff);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border-bottom: 2px solid var(--accent, #fff);
    padding-bottom: 12px;
  }

  .control-section {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .control-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .control-section h4 {
    margin: 0 0 16px 0;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--accent, rgba(255, 255, 255, 0.5));
    letter-spacing: 0.12em;
  }

  .boids-controls label {
    display: block;
    margin-bottom: 16px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.9);
  }

  .boids-controls label span {
    float: right;
    font-variant-numeric: tabular-nums;
    color: rgba(255, 255, 255, 0.6);
  }

  .boids-controls input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 1px;
    margin: 12px 0;
    padding: 0;
    background: rgba(255, 255, 255, 0.3);
    border: none;
    border-radius: 0;
    outline: none;
    cursor: pointer;
    display: block;
    box-sizing: border-box;
  }

  .boids-controls input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 8px;
    height: 8px;
    background: var(--accent, #fff);
    border-radius: 0;
    cursor: pointer;
    margin-top: -3.5px;
    transition: transform 0.1s ease;
  }

  .boids-controls input[type="range"]::-moz-range-thumb {
    width: 8px;
    height: 8px;
    background: var(--accent, #fff);
    border: none;
    border-radius: 0;
    cursor: crosshair;
  }

  .boids-controls select {
    width: 100%;
    margin-top: 8px;
    padding: 8px 12px;
    border: 1px solid var(--accent, rgba(255, 255, 255, 0.2));
    border-radius: 0;
    background: transparent;
    color: #fff;
    font-family: inherit;
    font-size: 12px;
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .boids-controls select:hover {
    border-color: var(--accent, rgba(255, 255, 255, 0.4));
  }

  .boids-controls select:focus {
    outline: none;
    border-color: var(--accent, #fff);
  }

  .boids-controls select option {
    background: #000;
    color: #fff;
  }

  .boids-controls small {
    display: block;
    margin-top: 4px;
    color: rgba(255, 255, 255, 0.4);
    font-size: 10px;
    letter-spacing: 0.02em;
  }

  .checkbox-label {
    display: flex !important;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    margin-bottom: 12px;
  }

  .checkbox-label input[type="checkbox"] {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    border: 1px solid var(--accent, rgba(255, 255, 255, 0.4));
    border-radius: 0;
    background: transparent;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .checkbox-label input[type="checkbox"]:checked {
    background: var(--accent, #fff);
    border-color: var(--accent, #fff);
  }

  .checkbox-label input[type="checkbox"]:checked::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 46%;
    width: 4px;
    height: 8px;
    border: solid #000;
    border-width: 0 2px 2px 0;
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .control-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 16px;
  }

  .control-row button {
    padding: 10px 16px;
    border: 1px solid var(--accent, rgba(255, 255, 255, 0.3));
    border-radius: 0;
    background: transparent;
    color: #fff;
    cursor: pointer;
    font-family: inherit;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.15s ease;
  }

  .control-row button:hover {
    background: var(--accent, #fff);
    color: #000;
    border-color: var(--accent, #fff);
  }

  .boids-controls::-webkit-scrollbar {
    width: 4px;
  }

  .boids-controls::-webkit-scrollbar-track {
    background: transparent;
  }

  .boids-controls::-webkit-scrollbar-thumb {
    background: var(--accent, rgba(255, 255, 255, 0.3));
    border-radius: 0;
  }

  .boids-controls::-webkit-scrollbar-thumb:hover {
    background: var(--accent, rgba(255, 255, 255, 0.5));
  }

  /* Light mode styles */
  @media (prefers-color-scheme: light) {
    .boids-toggle-btn {
      background: rgba(255, 255, 255, 0.95);
      border-color: var(--accent, rgba(0, 0, 0, 0.15));
      color: rgb(var(--gray-dark, 51, 51, 51));
    }

    .boids-toggle-btn:hover {
      background: var(--accent, #ff3c00);
      border-color: var(--accent, #ff3c00);
      color: #fff;
    }

    .boids-controls {
      background: rgba(255, 255, 255, 0.96);
      border-color: var(--accent, rgba(0, 0, 0, 0.12));
      color: rgb(var(--gray-dark, 51, 51, 51));
    }

    .boids-controls h3 {
      color: var(--accent, #ff3c00);
      border-bottom-color: var(--accent, #ff3c00);
    }

    .control-section {
      border-bottom-color: rgba(0, 0, 0, 0.08);
    }

    .control-section h4 {
      color: var(--accent, rgba(0, 0, 0, 0.5));
    }

    .boids-controls label {
      color: rgba(0, 0, 0, 0.85);
    }

    .boids-controls label span {
      color: rgba(0, 0, 0, 0.55);
    }

    .boids-controls input[type="range"] {
      background: rgba(0, 0, 0, 0.15);
    }

    .boids-controls input[type="range"]::-webkit-slider-thumb {
      background: var(--accent, #ff3c00);
    }

    .boids-controls input[type="range"]::-moz-range-thumb {
      background: var(--accent, #ff3c00);
    }

    .boids-controls select {
      border-color: var(--accent, rgba(0, 0, 0, 0.15));
      color: rgb(var(--gray-dark, 51, 51, 51));
      background: rgba(255, 255, 255, 0.8);
    }

    .boids-controls select:hover {
      border-color: var(--accent, rgba(0, 0, 0, 0.3));
    }

    .boids-controls select:focus {
      border-color: var(--accent, #ff3c00);
    }

    .boids-controls select option {
      background: #fff;
      color: rgb(var(--gray-dark, 51, 51, 51));
    }

    .boids-controls small {
      color: rgba(0, 0, 0, 0.45);
    }

    .checkbox-label input[type="checkbox"] {
      border-color: var(--accent, rgba(0, 0, 0, 0.3));
    }

    .checkbox-label input[type="checkbox"]:checked {
      background: var(--accent, #ff3c00);
      border-color: var(--accent, #ff3c00);
    }

    .checkbox-label input[type="checkbox"]:checked::after {
      border-color: #fff;
    }

    .control-row button {
      border-color: var(--accent, rgba(0, 0, 0, 0.2));
      color: rgb(var(--gray-dark, 51, 51, 51));
    }

    .control-row button:hover {
      background: var(--accent, #ff3c00);
      color: #fff;
      border-color: var(--accent, #ff3c00);
    }

    .boids-controls::-webkit-scrollbar-thumb {
      background: var(--accent, rgba(0, 0, 0, 0.2));
    }

    .boids-controls::-webkit-scrollbar-thumb:hover {
      background: var(--accent, rgba(0, 0, 0, 0.35));
    }
  }

  /* Icon sizing for control buttons */
  .boids-toggle-btn svg {
    width: 18px;
    height: 18px;
  }

  .control-row button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .control-row button svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
</style>

<script>
  import { initAllBoids } from "../scripts/boids/instance";

  // Astro bundles this module script once per page and defers it, so a single
  // initAllBoids() call wires up every <BoidsCanvas> container on the page.
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAllBoids);
  } else {
    initAllBoids();
  }
</script>
