---
// Swiss Style Lightbox - minimal, typographic, functional
---

<div class="lightbox" id="lightbox">
  <div class="lightbox-chrome">
    <div class="lightbox-header">
      <div class="lightbox-counter">
        <span class="current-index">01</span>
        <span class="separator">—</span>
        <span class="total-count">00</span>
      </div>
      <button class="lightbox-close" aria-label="Close">
        <span class="close-text">CLOSE</span>
        <span class="close-key">ESC</span>
      </button>
    </div>

    <div class="lightbox-stage">
      <button class="lightbox-nav lightbox-prev" aria-label="Previous image">
        <span class="nav-arrow">←</span>
      </button>

      <div class="lightbox-content">
        <div class="loading-bar"></div>
        <img id="lightbox-img" src="" alt="Full size photo" />
      </div>

      <button class="lightbox-nav lightbox-next" aria-label="Next image">
        <span class="nav-arrow">→</span>
      </button>
    </div>

    <div class="lightbox-footer">
      <div class="progress-track">
        <div class="progress-fill"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .lightbox.active {
    display: block;
  }

  .lightbox-chrome {
    width: 100%;
    height: 100%;
    background: #000;
    display: flex;
    flex-direction: column;
  }

  /* Header */
  .lightbox-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid #222;
  }

  .lightbox-counter {
    font-weight: 700;
    font-size: 1.25rem;
    color: #fff;
    letter-spacing: 0.05em;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .current-index {
    font-size: 2.5rem;
    line-height: 1;
    color: var(--accent);
  }

  .separator {
    color: #444;
  }

  .total-count {
    color: #666;
  }

  .lightbox-close {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.75rem 1rem;
    transition: all 0.2s ease;
  }

  .close-text {
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.15em;
    color: #fff;
  }

  .close-key {
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    color: #666;
    padding: 0.25rem 0.5rem;
    border: 1px solid #333;
  }

  .lightbox-close:hover .close-text {
    color: var(--accent);
  }

  .lightbox-close:hover .close-key {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Stage */
  .lightbox-stage {
    flex: 1;
    display: flex;
    align-items: center;
    min-height: 0;
    padding: 0 1rem;
  }

  .lightbox-content {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0;
    transform: scale(0.98);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .lightbox-content img.loaded {
    opacity: 1;
    transform: scale(1);
  }

  .loading-bar {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 2px;
    background: #222;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .loading-bar.visible {
    opacity: 1;
  }

  .loading-bar::after {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--accent);
    animation: loading 1s ease-in-out infinite;
  }

  @keyframes loading {
    0% {
      left: -100%;
    }
    50% {
      left: 0;
    }
    100% {
      left: 100%;
    }
  }

  /* Navigation */
  .lightbox-nav {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid #333;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .nav-arrow {
    font-size: 1.5rem;
    font-weight: 300;
    color: #fff;
    transition: color 0.2s ease;
  }

  .lightbox-nav:hover {
    border-color: var(--accent);
    background: var(--accent);
  }

  .lightbox-nav:hover .nav-arrow {
    color: #000;
  }

  /* Footer */
  .lightbox-footer {
    padding: 1.5rem 2rem;
    border-top: 1px solid #222;
  }

  .progress-track {
    width: 100%;
    height: 2px;
    background: #222;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--accent);
    width: 0%;
    transition: width 0.3s ease;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .lightbox-header {
      padding: 1rem;
    }

    .lightbox-counter {
      font-size: 1rem;
    }

    .current-index {
      font-size: 1.75rem;
    }

    .close-key {
      display: none;
    }

    .lightbox-stage {
      padding: 0;
    }

    .lightbox-nav {
      position: absolute;
      width: 60px;
      height: 60px;
      background: rgba(0, 0, 0, 0.8);
      border: none;
      z-index: 10;
    }

    .lightbox-prev {
      left: 0.5rem;
    }

    .lightbox-next {
      right: 0.5rem;
    }

    .lightbox-footer {
      padding: 1rem;
    }
  }
</style>

<script>
  function initLightbox() {
    const galleryItems = document.querySelectorAll(".gallery-item");
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
    const loadingBar = document.querySelector(".lightbox .loading-bar") as HTMLElement;
    const currentIndexEl = document.querySelector(".lightbox .current-index") as HTMLElement;
    const totalCountEl = document.querySelector(".lightbox .total-count") as HTMLElement;
    const progressFill = document.querySelector(".lightbox .progress-fill") as HTMLElement;

    if (!lightbox || !lightboxImg || !galleryItems.length) return;

    let currentIndex = 0;

    const images = Array.from(galleryItems).map((item) => {
      const img = item.querySelector("img") as HTMLImageElement;
      return {
        src: img.currentSrc || img.src,
        srcset: img.srcset,
        alt: img.alt,
      };
    });

    // Set total count
    totalCountEl.textContent = String(images.length).padStart(2, "0");

    function updateUI() {
      currentIndexEl.textContent = String(currentIndex + 1).padStart(2, "0");
      progressFill.style.width = `${((currentIndex + 1) / images.length) * 100}%`;
    }

    function showImage(index: number) {
      currentIndex = index;
      const imageData = images[index];

      lightboxImg.classList.remove("loaded");
      loadingBar.classList.add("visible");

      lightboxImg.srcset = imageData.srcset;
      lightboxImg.src = imageData.src;
      lightboxImg.alt = imageData.alt;

      updateUI();
    }

    lightboxImg.addEventListener("load", () => {
      lightboxImg.classList.add("loaded");
      loadingBar.classList.remove("visible");
    });

    function openLightbox(index: number) {
      showImage(index);
      lightbox?.classList.add("active");
      document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
      lightbox?.classList.remove("active");
      document.body.style.overflow = "";
    }

    function navigate(direction: number) {
      currentIndex = (currentIndex + direction + images.length) % images.length;
      showImage(currentIndex);
    }

    // Event listeners
    galleryItems.forEach((item, index) => {
      item.addEventListener("click", () => openLightbox(index));
    });

    lightbox.querySelector(".lightbox-close")?.addEventListener("click", closeLightbox);

    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox || (e.target as Element).classList.contains("lightbox-content")) {
        closeLightbox();
      }
    });

    lightbox.querySelector(".lightbox-prev")?.addEventListener("click", (e) => {
      e.stopPropagation();
      navigate(-1);
    });

    lightbox.querySelector(".lightbox-next")?.addEventListener("click", (e) => {
      e.stopPropagation();
      navigate(1);
    });

    document.addEventListener("keydown", (e) => {
      if (!lightbox.classList.contains("active")) return;

      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") navigate(-1);
      if (e.key === "ArrowRight") navigate(1);
    });

    // Touch swipe support
    let touchStartX = 0;
    lightbox.addEventListener(
      "touchstart",
      (e) => {
        touchStartX = e.touches[0].clientX;
      },
      { passive: true },
    );

    lightbox.addEventListener(
      "touchend",
      (e) => {
        const touchEndX = e.changedTouches[0].clientX;
        const diff = touchStartX - touchEndX;

        if (Math.abs(diff) > 50) {
          navigate(diff > 0 ? 1 : -1);
        }
      },
      { passive: true },
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLightbox);
  } else {
    initLightbox();
  }
</script>
