---
import { Image } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	backgroundImage?: any;
}

const { title, description, backgroundImage } = Astro.props;
---

<div class="page-header">
	{backgroundImage && (
		<Image src={backgroundImage} alt="Background" class="page-header-bg" />
	)}
	<div class="page-header-content">
		<h1>{title}</h1>
		<p>{description}</p>
	</div>
</div>

<style>
	.page-header {
		text-align: center;
		padding: 3em 1em;
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		min-height: 300px;
	}
	
	.page-header-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: -1;
		border-radius: 0;
	}
	
	.page-header-content {
		position: relative;
		z-index: 1;
	}
	
	.page-header h1 {
		margin: 0 0 0.5em 0;
		font-size: 2.5em;
		color: white;
	}
	
	.page-header p {
		margin: 0;
		color: lightgray;
		font-size: 1.1em;
	}
	
	@media (max-width: 640px) {
		.page-header {
			padding: 2em 1em;
			min-height: 200px;
		}
		
		.page-header h1 {
			font-size: 1.8em;
		}
	}
</style>
