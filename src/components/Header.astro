---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header>
  <div class="header-inner">
    <div class="logo-row">
      <h1><a href="/">{SITE_TITLE}<span class="dot">.</span></a></h1>
    </div>
    <hr class="header-divider" />
    <div class="nav-row">
      <nav>
        <HeaderLink href="/">Index</HeaderLink>
        <HeaderLink href="/boids-explained">Boids</HeaderLink>
        <HeaderLink href="https://github.com/thabnir">GitHub&nbsp;&#8599;</HeaderLink>
        <HeaderLink href="https://linkedin.com/in/henry-lefebvre">LinkedIn&nbsp;&#8599;</HeaderLink>
      </nav>
      <span class="header-meta mono">MINNEAPOLIS&nbsp;&nbsp;44.98&deg;N&nbsp;93.15&deg;W</span>
    </div>
  </div>

  <style>
    header {
      width: 100%;
      margin: 0;
      padding: 0;
    }

    .header-inner {
      box-sizing: border-box;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .logo-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5em 0 0.15em;
    }

    h1 {
      font-size: min(9vw, 128px);
      letter-spacing: -0.02em;
      margin: 0;
    }

    h1 a {
      text-decoration: none;
      color: var(--text-heading);
    }

    h1 a:hover {
      color: var(--text-heading);
    }

    .dot {
      color: var(--accent);
    }

    .header-divider {
      border: none;
      border-top: 2px solid var(--text-heading);
      margin: 0;
      width: 100%;
    }

    .nav-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1em;
      padding: 0.8em 0 0.5em;
    }

    nav {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 1.75em;
    }

    .header-meta {
      color: rgb(var(--gray));
      white-space: nowrap;
    }

    @media (max-width: 720px) {
      .header-inner {
        padding: 0 1em;
      }

      h1 {
        font-size: clamp(1.75rem, 10vw, 2.5rem);
      }

      nav {
        gap: 1.25em;
      }

      .header-meta {
        display: none;
      }
    }
  </style>
</header>
