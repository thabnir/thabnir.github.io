---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header>
  <div class="logo-row">
    <h1><a href="/">{SITE_TITLE}</a></h1>
  </div>
  <hr class="header-divider" />
  <nav>
    <HeaderLink href="/">About</HeaderLink>
    <span class="nav-separator">|</span>
    <HeaderLink href="/blog">Blog</HeaderLink>
    <span class="nav-separator">|</span>
    <HeaderLink href="/boids-explained">Boids</HeaderLink>
    <span class="nav-separator">|</span>
    <HeaderLink href="https://github.com/thabnir">GitHub</HeaderLink>
    <span class="nav-separator">|</span>
    <HeaderLink href="https://linkedin.com/in/henry-lefebvre">LinkedIn</HeaderLink>
  </nav>
  <!-- <hr class="header-divider" /> -->

  <style>
    header {
      box-sizing: border-box;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .logo-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5em 0 0.25em;
    }

    h1 {
      font-size: min(9vw, 128px);
      letter-spacing: -0.02em;
    }

    h1 a {
      text-decoration: none;
      color: var(--text-heading);
    }

    h1 a:hover {
      color: var(--text-heading);
    }

    .header-divider {
      border: none;
      border-top: 2px solid var(--text-heading);
      margin: -0.5em 0 0;
      width: 100vw;
      margin-left: calc(50% - 50vw);
    }

    nav {
      display: flex;
      align-items: center;
      gap: 0.5em;
      padding: 0.5em 0;
    }

    .nav-separator {
      color: var(--text-heading);
      font-weight: 300;
      user-select: none;
    }

    @media (max-width: 720px) {
      header {
        padding: 0 1em;
      }

      h1 {
        font-size: clamp(1.75rem, 10vw, 2.5rem);
      }

      .social-links {
        display: none;
      }
    }
  </style>
</header>
