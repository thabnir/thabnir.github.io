---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { Icon } from "astro-icon/components";
import BoidsCanvas from "../components/BoidsCanvas.astro";
const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>

  <div class="boids-background">
    <BoidsCanvas
      id="bg-boids"
      enableFpsLimit={true}
      fpsLimit={30}
      nBoids={1750}
      nBoidsMobile={300}
      boidSize={1}
      trailLength={100}
      drawTrail={true}
      colorMode="velocity"
      showVision={false}
      showStats={false}
      maxSpeed={1.5}
      alignmentFactor={0.0065}
      separationFactor={0.005}
      cohesionFactor={0.08}
      enableScrollControl={true}
    />
  </div>
  <body>
    <Header />
    <main>
      <p>
        I'm a software developer.<br />
        Don't confuse me with <i
          ><a href="https://en.wikipedia.org/wiki/Henri_Lefebvre" class="hover-picture">Henri Lefebvre</a></i
        >, the Marxist philosopher.<br />
        He's old, dead, and doesn't know <a href="/blog/typescript">the first thing about Typescript</a>.<br />
        I'm young, alive, and seeking employment after graduation.<br />
        To get in touch, <a href="mailto:henrylefeb@gmail.com">email me</a> or <a
          href="https://www.linkedin.com/in/henry-lefebvre/">message me on LinkedIn</a
        >.
      </p>
      <strong>
        <a href="/henry-lefebvre-resume.pdf" class="download-link">
          <Icon name="material-symbols:download" />
          <span>Download Resume</span>
        </a>
      </strong>
    </main>
  </body>
</html>
