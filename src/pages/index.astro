---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { Icon } from "astro-icon/components";
import BoidsCanvas from "../components/BoidsCanvas.astro";
const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>

  <div class="boids-background">
    <BoidsCanvas
      id="bg-boids"
      enableFpsLimit={true}
      fpsLimit={30}
      nBoids={1750}
      nBoidsMobile={300}
      boidSize={1}
      trailLength={100}
      drawTrail={true}
      colorMode="velocity"
      showVision={false}
      showStats={false}
      maxSpeed={1.5}
      alignmentFactor={0.0065}
      separationFactor={0.005}
      cohesionFactor={0.08}
      enableScrollControl={true}
      fieldOfView={130}
    />
  </div>
  <body>
    <Header />
    <main>
      <p>
        I'm a software developer.<br />
        Don't confuse me with <i
          ><a href="https://en.wikipedia.org/wiki/Henri_Lefebvre" class="hover-picture">Henri Lefebvre</a></i
        >, the Marxist philosopher.<br />
        He's old, dead, and doesn't know <a href="/blog/typescript">the first thing about Typescript</a>.<br />
        I'm young, alive, and seeking employment after graduation.<br />
        To get in touch, <a href="mailto:henrylefeb@gmail.com">email me</a> or <a
          href="https://www.linkedin.com/in/henry-lefebvre/">message me on LinkedIn</a
        >.
      </p>
      <strong>
        <a href="/henry-lefebvre-resume.pdf" class="download-link">
          <Icon name="material-symbols:download" />
          <span>Download Resume</span>
        </a>
      </strong>
    </main>

    <script>
      /**
       * Boid Parameter Automation
       * Switches between "Ordered" and "Chaotic" modes to keep the background interesting.
       */

      const CONFIG = {
        ORDERED_DURATION_MS: 15000,
        CHAOTIC_DURATION_MS: 8000,

        // Gives rise to a cell-like structure (cool)
        // Eventually simplifies into a few large groups moving straight (boring).
        // Takes about 15-20 seconds before it get boring, so switch to chaotic mode for a bit to re-scatter the boids.
        ORDERED_PARAMS: {
          alignmentFactor: 0.0065,
          cohesionFactor: 0.08,
          separationFactor: 0.005,
          fieldOfView: 130,
          minDistance: 10,
          maxSpeed: 1.5,
        },

        // Scatters the boids around. They look like wiggly worms.
        CHAOTIC_PARAMS: {
          alignmentFactor: 0.002,
          cohesionFactor: 0.001,
          separationFactor: 0.02,
          fieldOfView: 280,
          minDistance: 35,
          maxSpeed: 2.2,
        },
      };

      function initBoidAutomation() {
        const containerId = "bg-boids-container";

        // Wait for the instance to be ready
        const checkInterval = setInterval(() => {
          const w = window as any;
          if (w.boidsInstances && w.boidsInstances.has(containerId)) {
            clearInterval(checkInterval);
            startLoop(w.boidsInstances.get(containerId));
          }
        }, 100);
      }

      function startLoop(instance: any) {
        let isOrdered = true;

        const switchMode = () => {
          if (isOrdered) {
            instance.setParams(CONFIG.CHAOTIC_PARAMS);
            setTimeout(switchMode, CONFIG.CHAOTIC_DURATION_MS);
          } else {
            instance.setParams(CONFIG.ORDERED_PARAMS);
            setTimeout(switchMode, CONFIG.ORDERED_DURATION_MS);
          }
          isOrdered = !isOrdered;
        };

        setTimeout(switchMode, CONFIG.ORDERED_DURATION_MS);
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initBoidAutomation);
      } else {
        initBoidAutomation();
      }
    </script>
  </body>
</html>
