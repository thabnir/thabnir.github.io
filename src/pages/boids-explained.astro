---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import BoidsCanvas from "../components/BoidsCanvas.astro";
import { SITE_TITLE } from "../consts";
import "katex/dist/katex.min.css";
import { Prism } from "@astrojs/prism";
import { Icon } from "astro-icon/components";

const CODE_SEPARATE = `function separate(boid, neighbors) {
  let steer = { x: 0, y: 0 };

  for (const other of neighbors) {
    if (distance(boid, other) < MIN_DISTANCE) {
      // Flee from nearby boids
      steer.x += boid.x - other.x;
      steer.y += boid.y - other.y;
    }
  }

  return steer;
}`;

const CODE_ALIGN = `function align(boid, neighbors) {
  let avgVelocity = { x: 0, y: 0 };
  let count = 0;

  for (const other of neighbors) {
    if (distance(boid, other) < VISUAL_RANGE) {
      avgVelocity.x += other.dx;
      avgVelocity.y += other.dy;
      count++;
    }
  }

  // Steer toward average direction
  return normalize(avgVelocity);
}`;

const CODE_COHERE = `function cohere(boid, neighbors) {
  let center = { x: 0, y: 0 };
  let count = 0;

  for (const other of neighbors) {
    if (distance(boid, other) < VISUAL_RANGE) {
      center.x += other.x;
      center.y += other.y;
      count++;
    }
  }

  // Steer toward flock center
  center.x /= count;
  center.y /= count;
  return steerToward(boid, center);
}`;

const CODE_SPATIAL_HASH = `class SpatialHashGrid {
  findNearby(x, y, range) {
    const nearby = [];
    const cellRadius = Math.ceil(range / this.cellSize);

    // Only check cells within range
    for (let dx = -cellRadius; dx <= cellRadius; dx++) {
      for (let dy = -cellRadius; dy <= cellRadius; dy++) {
        const cell = this.getCell(x + dx, y + dy);
        if (cell) nearby.push(...cell);
      }
    }

    return nearby;
  }
}`;

const CODE_UPDATE = `function update(boid, neighbors) {
  // Apply all three rules
  boid.velocity += separate(boid, neighbors);
  boid.velocity += align(boid, neighbors);
  boid.velocity += cohere(boid, neighbors);

  // And update the boid's position
  boid.position += boid.velocity;
}`;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Boids`}
      description="An interactive exploration of emergent flocking behavior through Craig Reynolds' Boids algorithm"
    />
    <style>
      /*
        NOTE: this page uses Astro's scoped CSS.
        Defining variables on :root inside scoped CSS does NOT reliably apply to the
        actual document root, so var(--code-*) ended up undefined and Prism tokens
        looked “unhighlighted”.

        Define variables on a real element in this page instead.
      */
      .content-wrapper {
        --section-height: 100vh;

        /* Light mode overlays (default in this site) */
        --bg-overlay: rgba(255, 255, 255, 0.92);
        --bg-overlay-light: rgba(255, 255, 255, 0.55);

        /* Swiss-style code palette (light mode) */
        --code-keyword: var(--accent);
        --code-function: rgb(var(--black));
        --code-comment: rgba(var(--gray), 0.9);
        --code-number: #0b6bcb;
        --code-string: #0b6bcb;
        --code-operator: rgba(var(--gray), 0.95);

        --code-punctuation: rgba(var(--gray), 0.9);

        /* Layout spacing standardization */
        --spacing-mobile: 1.5rem;
        --spacing-desktop: 2rem;
      }

      /* Dark mode overlays */
      @media (prefers-color-scheme: dark) {
        .content-wrapper {
          --bg-overlay: rgba(0, 0, 0, 0.9);
          --bg-overlay-light: rgba(0, 0, 0, 0.4);

          /* Swiss-style code palette (dark mode) */
          --code-keyword: var(--accent);
          --code-function: rgb(var(--black));
          --code-comment: rgba(var(--gray), 0.85);
          --code-number: #79c0ff;
          --code-string: #79c0ff;
          --code-operator: rgba(var(--gray-dark), 0.95);
          --code-punctuation: rgba(var(--gray-dark), 0.85);
        }
      }

      html {
        scroll-behavior: smooth;
        overscroll-behavior-y: none;
        background-color: var(--bg-primary);
      }

      /* Fixed background boids - always visible at partial opacity.
         Sections that need to hide them use their own solid backgrounds. */
      .boids-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        opacity: 0.5;
        pointer-events: none;
      }

      /* Hero section */
      .hero {
        position: relative;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 2rem;
        box-sizing: border-box;
      }

      .hero-title {
        font-size: clamp(4rem, 15vw, 12rem);
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 0.9;
        margin: 0;
        text-transform: uppercase;
        color: var(--text-heading);
      }

      .hero-subtitle {
        font-size: clamp(1rem, 2.5vw, 1.5rem);
        font-weight: 400;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-top: 2rem;
        opacity: 0.7;
      }

      .scroll-indicator {
        position: absolute;
        left: 50%;
        bottom: calc(7rem + env(safe-area-inset-bottom, 0px));
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        opacity: 0.5;
        text-decoration: none;
        color: inherit;
        transition: opacity 0.2s ease;
        cursor: pointer;
      }

      .scroll-indicator:hover {
        opacity: 1;
      }

      /* Bounce the text + arrow together without interfering with centering transforms. */
      .scroll-indicator-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        animation: bounce 2s infinite;
        will-change: transform;
      }

      .scroll-indicator span {
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .scroll-arrow {
        width: 24px;
        height: 24px;
        border-right: 2px solid currentColor;
        border-bottom: 2px solid currentColor;
        transform: rotate(45deg);
      }

      @keyframes bounce {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(8px);
        }
      }

      .jump-link {
        position: fixed;
        top: 80px;
        right: 2rem;
        z-index: 100;
        padding: 0.75rem 1.5rem;
        background: var(--bg-primary, rgba(0, 0, 0, 0.8));
        border: 1px solid var(--accent, #ff3c00);
        color: var(--text-primary, #fff);
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .jump-link:hover {
        background: var(--accent, #ff3c00);
        color: #000;
      }

      /* Section styling */
      .section {
        min-height: var(--section-height);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4rem var(--spacing-desktop);
        box-sizing: border-box;
        position: relative;
      }

      /* Increase vertical padding on mobile for better spacing */
      @media (max-width: 768px) {
        .section {
          padding: 6rem var(--spacing-mobile);
        }

        /* STRICTLY reset demo section padding so overlay handles it alone.
           This prevents "double padding" (1.5rem from parent + 1.5rem from overlay). */
        .demo-section {
          padding: 0;
        }
      }

      .section-content {
        max-width: 900px;
        width: 100%;
      }

      .section-number {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        color: var(--accent, #ff3c00);
        margin-bottom: 1rem;
      }

      .section-title {
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.1;
        margin: 0 0 2rem 0;
      }

      .section-text {
        font-size: 1.25rem;
        line-height: 1.8;
        opacity: 0.85;
        max-width: 65ch;
      }

      .section-text p {
        margin: 0 0 1.5rem 0;
      }

      /* Split layout */
      .split-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
      }

      @media (max-width: 900px) {
        .split-section {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }

      /*
        Code blocks are rendered by the <Prism /> component.
        In Astro, scoped styles compile to selectors like:
          .code-block[data-astro-cid-xxxx]
        but Prism's generated <pre> does NOT carry this page's cid attribute.
        Therefore, the rules below must be global.
      */
      :global(pre.code-block) {
        box-sizing: border-box;
        width: 100%;
        max-width: 100%;
        margin: 1.5rem 0;
        padding: 1.25rem 1.25rem;

        /* background: rgba(var(--gray-light), 0.8); */
        /* background: var(--bg-primary); */
        /* background: rgba(var(--bg-primary), 1); */
        /* border: 1px solid rgba(var(--gray), 0.32); */

        border-left: 4px solid var(--accent, #ff3c00);
        border-radius: 0;

        font-family:
          "Geist Mono", ui-monospace, "SF Mono", SFMono-Regular, Menlo, Monaco,
          Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 0.9rem;
        line-height: 1.65;
        letter-spacing: 0;
        font-variant-ligatures: none;
        tab-size: 2;
        color: var(--text-primary);

        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      /* Separation demo: slightly more opaque code background for readability. */
      :global(
        .content-wrapper section[data-section="separation"] pre.code-block
      ) {
        background: rgba(var(--gray-light), 0.26);
        border-color: rgba(var(--gray), 0.38);
      }

      :global(pre.code-block > code) {
        font-family: inherit;
        font-size: inherit;
        display: block;
        white-space: pre;
      }

      /* PrismJS token colors */
      :global(pre.code-block .token.keyword),
      :global(pre.code-block .token.class-name) {
        color: var(--code-keyword);
        font-weight: 650;
      }

      :global(pre.code-block .token.function) {
        color: var(--code-function);
        font-weight: 650;
      }

      :global(pre.code-block .token.comment) {
        color: var(--code-comment);
        font-style: italic;
      }

      :global(pre.code-block .token.number) {
        color: var(--code-number);
      }

      :global(pre.code-block .token.string) {
        color: var(--code-string);
      }

      :global(pre.code-block .token.operator) {
        color: var(--code-operator);
      }

      :global(pre.code-block .token.punctuation) {
        color: var(--code-punctuation);
      }

      :global(pre.code-block .token.constant),
      :global(pre.code-block .token.boolean) {
        color: var(--code-keyword);
        font-weight: 650;
      }

      :global(pre.code-block .token.parameter),
      :global(pre.code-block .token.property),
      :global(pre.code-block .token.literal-property) {
        color: var(--text-primary);
      }

      /* Demo section with embedded boids */
      .demo-section {
        position: relative;
        min-height: 100vh;
        /* RESET padding: overlay handles the spacing internally */
        padding: 0;
        overflow: hidden;
        /* Solid background hides the fixed background boids layer */
        background: var(--bg-primary);
      }

      /* Smooth fade-in/out edges so demo sections don't "pop" */
      .demo-section::before {
        content: "";
        position: absolute;
        top: -120px;
        left: 0;
        right: 0;
        height: 120px;
        background: linear-gradient(to bottom, transparent, var(--bg-primary));
        pointer-events: none;
        z-index: 1;
      }

      .demo-section::after {
        content: "";
        position: absolute;
        bottom: -120px;
        left: 0;
        right: 0;
        height: 120px;
        background: linear-gradient(to top, transparent, var(--bg-primary));
        pointer-events: none;
        z-index: 1;
      }

      /* Override the generic .section flex layout for demo sections.
         Flex + absolutely-positioned children can collapse width/height. */
      .section.demo-section {
        display: block;
      }

      /* On mobile, use flex column to let content flow naturally */
      @media (max-width: 768px) {
        .section.demo-section {
          display: flex;
          flex-direction: column;
          height: auto;
          min-height: 100vh;
        }
      }

      /* Zoom POV uses a sticky viewport-height stage */
      .zoom-sticky-container {
        width: 100%;
        height: 100vh;
        overflow: hidden;
      }

      /* Sticky does not behave correctly inside overflow:hidden ancestors.
         Let the section overflow be visible, and clip inside the sticky stage instead. */
      .zoom-pov-section {
        overflow: visible;
      }

      .demo-boids {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
      }

      /* On mobile, the canvas should stay fixed in background of the section */
      @media (max-width: 768px) {
        .demo-boids {
          position: absolute;
          height: 100%;
        }
      }

      .demo-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        /* Keep boids visible: fade to transparent rather than covering the whole stage. */
        background: linear-gradient(
          90deg,
          var(--bg-overlay, rgba(0, 0, 0, 0.9)) 0%,
          var(--bg-overlay-light, rgba(0, 0, 0, 0.4)) 55%,
          transparent 100%
        );
        pointer-events: none;
        padding: 0 clamp(1.25rem, 6vw, 6rem);
        box-sizing: border-box;
      }

      /*
        Separation (Personal Space): we follow a centered boid and draw its vision.
        Use a centered radial vignette to fade from the boid to the *opaque* page
        background, avoiding harsh cutoffs and making “outside vision” feel dim.
      */
      .demo-overlay--separation {
        /* Defaults; can be overridden inline on the element if the demo props change. */
        --vision-radius: 200px; /* visualRange(40) * zoomLevel(5) */
        --vision-feather: 96px;

        /* Only darken outward from center, no inner glow */
        background: radial-gradient(
          circle at 50% 50%,
          transparent 0,
          transparent var(--vision-radius),
          var(--bg-overlay-light, rgba(0, 0, 0, 0.4))
            calc(var(--vision-radius) - 18px),
          var(--bg-overlay, rgba(0, 0, 0, 0.9))
            calc(var(--vision-radius) + 200px),
          var(--bg-primary) 100%
        );
      }

      .demo-overlay .section-content {
        pointer-events: auto;
        text-align: left;
        padding: 2rem 0;
        margin: 0 auto;
        width: min(900px, 100%);
        box-sizing: border-box;
      }

      .demo-overlay .section-text {
        max-width: 65ch;
      }

      .jump-link.is-hidden {
        opacity: 0;
        transform: translateY(-8px);
        pointer-events: none;
      }

      /* Zoom POV overlay panel */
      .zoom-overlay {
        justify-content: flex-start;
        align-items: flex-start;
        padding: 0;
        background: linear-gradient(
          180deg,
          var(--bg-overlay, rgba(0, 0, 0, 0.8)) 0%,
          transparent 28%,
          transparent 72%,
          var(--bg-overlay, rgba(0, 0, 0, 0.8)) 100%
        );
      }

      /* NYT-style scroll blurbs for zoom section */
      .zoom-blurb {
        position: absolute;
        left: clamp(1rem, 4vw, 4rem);
        max-width: min(320px, calc(50% - 2rem));
        padding: 1rem 1.25rem;
        background: var(--bg-overlay);
        border-left: 3px solid var(--accent);
        font-size: 1rem;
        line-height: 1.6;
        opacity: 0;
        transform: translateY(12px);
        transition:
          opacity 300ms ease,
          transform 300ms ease;
        pointer-events: none;
        z-index: 10;
      }

      .zoom-blurb.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .zoom-blurb p {
        margin: 0;
      }

      .zoom-blurb strong {
        color: var(--accent);
      }

      /* Position each blurb at different vertical spots */
      .zoom-blurb-1 {
        top: 15%;
      }
      .zoom-blurb-2 {
        top: 35%;
      }
      .zoom-blurb-3 {
        top: 55%;
      }
      .zoom-blurb-4 {
        top: 75%;
      }

      @media (max-width: 768px) {
        .zoom-blurb {
          left: 1rem;
          right: auto;
          max-width: calc(45% - 1rem);
          font-size: 0.9rem;
          padding: 0.75rem 1rem;
        }
      }

      /* Rules list */
      .rules-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin: 3rem 0;
      }

      @media (max-width: 768px) {
        .rules-grid {
          grid-template-columns: 1fr;
        }
      }

      .rule-card {
        background: rgba(var(--gray-light), 0.18);
        border: 1px solid rgba(var(--gray), 0.22);
        padding: 2rem;
        transition: all 0.3s ease;
      }

      .rule-card:hover {
        background: rgba(var(--gray-light), 0.28);
        border-color: var(--accent, #ff3c00);
      }

      /* Mobile/narrow: content flows naturally */
      @media (max-width: 768px) {
        .demo-overlay {
          position: relative;
          height: auto;
          /* Use standard mobile padding */
          padding: 6rem var(--spacing-mobile);
          background: linear-gradient(
            180deg,
            var(--bg-overlay, rgba(0, 0, 0, 0.9)) 0%,
            var(--bg-overlay-light, rgba(0, 0, 0, 0.4)) 40%,
            transparent 100%
          );
          pointer-events: none;
        }

        /* Update gradient for separation section on mobile */
        .demo-overlay--separation {
          background: radial-gradient(
            circle at 50% 30%,
            transparent 0,
            transparent var(--vision-radius),
            var(--bg-overlay-light, rgba(0, 0, 0, 0.4))
              calc(var(--vision-radius) - 18px),
            var(--bg-overlay, rgba(0, 0, 0, 0.9))
              calc(var(--vision-radius) + 200px),
            var(--bg-primary) 100%
          );
        }

        .demo-overlay .section-content {
          width: 100%;
          padding: 0;
          pointer-events: auto;
        }
      }

      .rule-number {
        font-size: 3rem;
        font-weight: 900;
        color: var(--accent, #ff3c00);
        line-height: 1;
        margin-bottom: 1rem;
      }

      .rule-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
      }

      .rule-desc {
        font-size: 0.95rem;
        opacity: 0.7;
        line-height: 1.6;
      }

      /* Fade out boids at bottom of rules section before demo begins */
      .section[data-section="rules"]::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 120px;
        background: linear-gradient(to bottom, transparent, var(--bg-primary));
        pointer-events: none;
        z-index: 10;
      }

      /* Full experience section */
      .full-experience {
        min-height: 100vh;
        padding: 0;
        position: relative;
        /* Solid background hides the fixed background boids layer */
        background: var(--bg-primary);
      }

      /* Smooth fade-in edge at top so it doesn't pop in */
      .full-experience::before {
        content: "";
        position: absolute;
        top: -120px;
        left: 0;
        right: 0;
        height: 120px;
        background: linear-gradient(to bottom, transparent, var(--bg-primary));
        pointer-events: none;
        z-index: 1;
      }

      .full-boids-container {
        position: relative;
        width: 100%;
        height: 100vh;
        /* Avoid a distracting “peek” of the default canvas state while this section
           is only barely visible at the bottom of the viewport. */
        opacity: 0;
        transform: translateY(12px);
        transition:
          opacity 240ms ease,
          transform 240ms ease;
        pointer-events: none;
      }

      .full-experience.is-active .full-boids-container {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .experience-header {
        position: absolute;
        top: 2rem;
        left: 2rem;
        z-index: 10;
        background: var(--bg-primary, rgba(0, 0, 0, 0.8));
        padding: 1.5rem 2rem;
        border: 1px solid rgba(var(--gray), 0.25);
      }

      .experience-header h2 {
        margin: 0 0 0.5rem 0;
        font-size: 1.5rem;
        font-weight: 700;
      }

      .experience-header p {
        margin: 0;
        font-size: 0.9rem;
        opacity: 0.7;
      }

      /* Playground header */
      .playground-header {
        position: absolute;
        top: 2rem;
        left: 2rem;
        z-index: 10;
        max-width: 400px;
      }

      .playground-header .section-number {
        display: block;
        margin-bottom: 0.5rem;
      }

      .playground-header .section-title {
        font-size: 2rem;
        margin-bottom: 1rem;
      }

      .playground-hint {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--bg-overlay, rgba(255, 255, 255, 0.95));
        padding: 0.75rem 1rem;
        border-left: 3px solid var(--accent, #ff3c00);
        font-size: 0.9rem;
        animation: fadeInUp 0.4s ease 0.8s both;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .playground-hint.hidden {
        display: none;
      }

      .hint-close {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.25rem;
        line-height: 1;
        opacity: 0.7;
        transition:
          opacity 0.2s,
          color 0.2s;
        color: var(--accent, #ff3c00);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .hint-close svg {
        width: 1.25rem;
        height: 1.25rem;
      }

      .hint-close:hover {
        opacity: 1;
      }

      /* Zoom section specific styling - transparent to show bg boids */
      .zoom-section {
        background: transparent;
        min-height: 70vh;
        align-items: flex-end;
        /* Use standard padding */
        padding: 6rem var(--spacing-desktop) 2.5rem;
        position: relative;
      }

      @media (max-width: 768px) {
        .zoom-section {
          padding: 6rem var(--spacing-mobile) 2.5rem;
          min-height: 50vh; /* Reduced height on mobile */
        }
      }

      /* Smooth fade from opaque background to transparent */
      .zoom-section::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 120px;
        background: linear-gradient(to bottom, var(--bg-primary), transparent);
        pointer-events: none;
        z-index: 5;
      }

      .zoom-section .section-content {
        position: relative;
        z-index: 10;
        /* Remove inner padding to match width of other sections */
        padding: 0;
      }

      /* Quote block */
      .quote-block {
        border-left: 4px solid var(--accent, #ff3c00);
        padding-left: 2rem;
        margin: 2rem 0;
        font-style: italic;
        font-size: 1.5rem;
        line-height: 1.6;
        opacity: 0.9;
      }

      .quote-author {
        font-size: 0.9rem;
        font-style: normal;
        opacity: 0.6;
        margin-top: 1rem;
      }

      /* Swiss Style Footer */
      .swiss-footer {
        padding: 4rem 2rem;
        /* background: var(--bg-primary, #000); */
        background: var(--bg-primary);
        border-top: 1px solid rgba(var(--gray), 0.25);
      }

      .footer-grid {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 3rem;
      }

      @media (max-width: 900px) {
        .footer-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 500px) {
        .footer-grid {
          grid-template-columns: 1fr;
        }
      }

      .footer-col h4 {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent, #ff3c00);
