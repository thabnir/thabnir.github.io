---
import { Prism } from "@astrojs/prism";
import BoidsSocialImage from "../assets/boids-og.png";
import BaseHead from "../components/BaseHead.astro";
import BoidsCanvas from "../components/BoidsCanvas.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
import "../styles/boids-explained.css";

const CODE_SEPARATE = `function separate(boid, neighbors) {
  return neighbors
    .filter((other) => distance(boid, other) < MIN_DISTANCE)
    .reduce((steer, other) => ({
      x: steer.x + boid.x - other.x,
      y: steer.y + boid.y - other.y,
    }), { x: 0, y: 0 });
}`;

const CODE_ALIGN = `function align(boid, neighbors) {
  if (neighbors.length === 0) return { x: 0, y: 0 };

  const average = mean(neighbors.map((other) => other.velocity));
  return {
    x: average.x - boid.velocity.x,
    y: average.y - boid.velocity.y,
  };
}`;

const CODE_COHERE = `function cohere(boid, neighbors) {
  if (neighbors.length === 0) return { x: 0, y: 0 };

  const center = mean(neighbors.map((other) => other.position));
  return {
    x: center.x - boid.position.x,
    y: center.y - boid.position.y,
  };
}`;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Boids — An Interactive Explainer | ${SITE_TITLE}`}
      description="See how separation, alignment, and cohesion turn local decisions into lifelike flocking — then tune the rules yourself."
      image={BoidsSocialImage}
    />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#050505" media="(prefers-color-scheme: dark)" />
  </head>

  <body class="boids-page">
    <a class="skip-link" href="#main-content">Skip to the explainer</a>

    <div class="site-header">
      <Header />
    </div>

    <main id="main-content" class="boids-story">
      <section class="boids-hero" id="top" aria-labelledby="hero-title">
        <div class="hero-canvas" aria-hidden="true">
          <BoidsCanvas
            id="hero-boids"
            nBoids={2500}
            nBoidsMobile={800}
            boidSize={9}
            visualRange={42}
            minDistance={13}
            drawTrail={true}
            colorMode="velocity"
            enableFpsLimit={true}
            showVision={false}
          />
        </div>
        <div class="hero-wash" aria-hidden="true"></div>

        <div class="story-shell hero-grid">
          <div class="hero-meta mono-label">
            <span>Interactive study / 01</span>
            <span class="live-label"><i></i> Simulation running</span>
          </div>

          <div class="hero-copy">
            <p class="eyebrow">Emergent motion, explained from the inside</p>
            <h1 id="hero-title">
              <span class="hero-word">Boids</span>
              <span class="hero-claim">No leader. No map. <em>Together? A flock.</em></span>
            </h1>
            <p class="hero-deck">
              Each agent can see only a few neighbors. Three tiny steering decisions turn that limited view into motion
              that feels coordinated, alive, and larger than any one boid.
            </p>
            <div class="hero-actions">
              <a class="text-button text-button--primary" href="#premise">Start with one boid <span>↓</span></a>
              <a class="text-button" href="#playground">Tune the flock <span>↘</span></a>
            </div>
          </div>

          <ol class="hero-rule-index" aria-label="The three flocking rules">
            <li><a href="#separation"><span>01</span><strong>Separation</strong><small>Make room</small></a></li>
            <li><a href="#alignment"><span>02</span><strong>Alignment</strong><small>Match motion</small></a></li>
            <li><a href="#cohesion"><span>03</span><strong>Cohesion</strong><small>Stay near</small></a></li>
          </ol>
        </div>
      </section>

      <section class="premise-section" id="premise" aria-labelledby="premise-title">
        <div class="story-shell">
          <div class="section-rail mono-label">
            <span>01</span>
            <span>The premise</span>
            <span>Local input → global pattern</span>
          </div>

          <div class="premise-grid">
            <h2 id="premise-title">A flock is not commanded.<br />It is negotiated.</h2>
            <div class="premise-copy">
              <p class="lede">
                In 1986, Craig Reynolds showed that convincing group motion does not require choreography. Give every
                bird-like agent the same small loop and let the pattern emerge.
              </p>
              <p>
                A boid has no map of the flock, no destination shared with everyone, and no idea what the overall shape
                should be. It only reacts to what is nearby, one frame at a time.
              </p>
            </div>
          </div>

          <ol class="decision-loop" aria-label="The decision loop each boid repeats">
            <li>
              <span class="loop-number">01</span>
              <h3>Notice</h3>
              <p>Find the neighbors inside a limited radius and field of view.</p>
            </li>
            <li>
              <span class="loop-number">02</span>
              <h3>Propose</h3>
              <p>Turn crowding, headings, and positions into three steering vectors.</p>
            </li>
            <li>
              <span class="loop-number">03</span>
              <h3>Move</h3>
              <p>Add the vectors, limit the turn, move forward, and repeat.</p>
            </li>
          </ol>
        </div>
      </section>

      <section class="rule-chapter rule-chapter--separation" id="separation" aria-labelledby="separation-title">
        <div class="story-shell chapter-grid">
          <div class="chapter-copy">
            <div class="chapter-kicker mono-label">
              <span>02 / Rule 01</span>
              <span>Keep space</span>
            </div>
            <h2 id="separation-title">Separation</h2>
            <p class="chapter-thesis">Too close? Turn away.</p>
            <p class="chapter-body">
              When another boid enters the red safety radius, the tracked boid proposes a turn in the opposite
              direction. Several nearby boids become one combined push, so the response is strongest where the crowd is
              densest.
            </p>
            <div class="rule-logic">
              <span>If distance &lt; minimum</span>
              <strong>add an away vector</strong>
            </div>
          </div>

          <figure class="rule-visual">
            <div class="visual-header mono-label">
              <span class="live-label"><i></i> Live local view</span>
              <span>Tracked boid / orange</span>
            </div>
            <div class="visual-window">
              <div class="rule-canvas" aria-hidden="true">
                <BoidsCanvas
                  id="rule-separation"
                  nBoids={160}
                  nBoidsMobile={90}
                  boidSize={11}
                  visualRange={48}
                  minDistance={26}
                  separationFactor={0.03}
                  alignmentFactor={0}
                  cohesionFactor={0}
                  colorMode="uniform"
                  uniformHue={0}
                  drawTrail={false}
                  maxSpeed={0.7}
                  minSpeed={0.4}
                  maxTurnRate={0.06}
                  fieldOfView={360}
                  enableFpsLimit={true}
                  followBoid={true}
                  zoomLevel={4.5}
                  zoomSmoothing={1}
                  cameraSmoothing={0.5}
                  showVision={true}
                  showVisionCone={true}
                  explanationMode="separation"
                />
              </div>
            </div>
            <figcaption class="visual-legend">
              <span><i class="legend-ring legend-ring--red"></i>Safety radius</span>
              <span><i class="legend-arrow legend-arrow--red"></i>Combined push</span>
              <span><i class="legend-boid"></i>Boid + heading</span>
            </figcaption>
          </figure>

          <details class="code-panel" open>
            <summary>
              <span class="code-label">Function</span>
              <code>separate(boid, neighbors)</code>
              <span class="code-toggle">Code</span>
            </summary>
            <Prism class="code-block" lang="ts" code={CODE_SEPARATE} />
          </details>
        </div>
      </section>

      <section class="rule-chapter rule-chapter--alignment" id="alignment" aria-labelledby="alignment-title">
        <div class="story-shell chapter-grid">
          <div class="chapter-copy">
            <div class="chapter-kicker mono-label">
              <span>03 / Rule 02</span>
              <span>Share direction</span>
            </div>
            <h2 id="alignment-title">Alignment</h2>
            <p class="chapter-thesis">Where are the neighbors heading?</p>
            <p class="chapter-body">
              The small green arrows are nearby headings. Their average becomes the larger green proposal on the tracked
              boid. It does not copy any single neighbor; it continuously compromises with the group it can currently
              see.
            </p>
            <div class="rule-logic">
              <span>Mean of visible velocities</span>
              <strong>steer toward that heading</strong>
            </div>
          </div>

          <figure class="rule-visual">
            <div class="visual-header mono-label">
              <span class="live-label"><i></i> Live local view</span>
              <span>Headings update every frame</span>
            </div>
            <div class="visual-window">
              <div class="rule-canvas" aria-hidden="true">
                <BoidsCanvas
                  id="rule-alignment"
                  nBoids={320}
                  nBoidsMobile={100}
                  boidSize={10}
                  visualRange={76}
                  minDistance={13}
                  separationFactor={0.002}
                  alignmentFactor={0.09}
                  cohesionFactor={0}
                  colorMode="velocity"
                  drawTrail={true}
                  trailLength={20}
                  maxSpeed={1.45}
                  minSpeed={1}
                  maxTurnRate={0.045}
                  fieldOfView={360}
                  wallMargin={35}
                  wallTurnFactor={0.45}
                  enableFpsLimit={true}
                  followBoid={true}
                  zoomLevel={3.2}
                  zoomSmoothing={1}
                  cameraSmoothing={0.5}
                  showVision={true}
                  showVisionCone={true}
                  explanationMode="alignment"
                />
              </div>
            </div>
            <figcaption class="visual-legend">
              <span><i class="legend-arrow legend-arrow--green legend-arrow--small"></i>Neighbor headings</span>
              <span><i class="legend-arrow legend-arrow--green"></i>Average heading</span>
              <span><i class="legend-ring legend-ring--blue"></i>Visible radius</span>
            </figcaption>
          </figure>

          <details class="code-panel" open>
            <summary>
              <span class="code-label">Function</span>
              <code>align(boid, neighbors)</code>
              <span class="code-toggle">Code</span>
            </summary>
            <Prism class="code-block" lang="ts" code={CODE_ALIGN} />
          </details>
        </div>
      </section>

      <section class="rule-chapter rule-chapter--cohesion" id="cohesion" aria-labelledby="cohesion-title">
        <div class="story-shell chapter-grid">
          <div class="chapter-copy">
            <div class="chapter-kicker mono-label">
              <span>04 / Rule 03</span>
              <span>Stay connected</span>
            </div>
            <h2 id="cohesion-title">Cohesion</h2>
            <p class="chapter-thesis">Where is the local middle?</p>
            <p class="chapter-body">
              Average the positions of visible neighbors and a temporary center appears. The blue cross marks that
              point; the dashed arrow is the boid's proposal to move toward it. As neighbors change, the center moves
              too.
            </p>
            <div class="rule-logic">
              <span>Mean of visible positions</span>
              <strong>steer toward that center</strong>
            </div>
          </div>

          <figure class="rule-visual">
            <div class="visual-header mono-label">
              <span class="live-label"><i></i> Live local view</span>
              <span>Center is local, not global</span>
            </div>
            <div class="visual-window">
              <div class="rule-canvas" aria-hidden="true">
                <BoidsCanvas
                  id="rule-cohesion"
                  nBoids={320}
                  nBoidsMobile={100}
                  boidSize={10}
                  visualRange={76}
                  minDistance={13}
                  separationFactor={0.0015}
                  alignmentFactor={0}
                  cohesionFactor={0.009}
                  colorMode="velocity"
                  drawTrail={true}
                  trailLength={20}
                  maxSpeed={1.45}
                  minSpeed={1}
                  maxTurnRate={0.055}
                  fieldOfView={360}
                  enableFpsLimit={true}
                  followBoid={true}
                  zoomLevel={3.2}
                  zoomSmoothing={1}
                  cameraSmoothing={0.5}
                  showVision={true}
                  showVisionCone={true}
                  explanationMode="cohesion"
                />
              </div>
            </div>
            <figcaption class="visual-legend">
              <span><i class="legend-cross"></i>Local center</span>
              <span><i class="legend-arrow legend-arrow--blue"></i>Cohesion pull</span>
              <span><i class="legend-ring legend-ring--blue"></i>Visible radius</span>
            </figcaption>
          </figure>

          <details class="code-panel" open>
            <summary>
              <span class="code-label">Function</span>
              <code>cohere(boid, neighbors)</code>
              <span class="code-toggle">Code</span>
            </summary>
            <Prism class="code-block" lang="ts" code={CODE_COHERE} />
          </details>
        </div>
      </section>

      <section class="pov-section" id="boids-eye" aria-labelledby="pov-title">
        <div class="pov-stage">
          <div class="pov-canvas" aria-hidden="true">
            <BoidsCanvas
              id="boids-eye-canvas"
              nBoids={720}
              nBoidsMobile={170}
              boidSize={10}
              visualRange={66}
              minDistance={20}
              separationFactor={0.012}
              alignmentFactor={0.038}
              cohesionFactor={0.0012}
              colorMode="velocity"
              drawTrail={true}
              trailLength={26}
              maxSpeed={1.35}
              minSpeed={0.9}
              maxTurnRate={0.06}
              fieldOfView={260}
              enableFpsLimit={true}
              followBoid={true}
              zoomLevel={1}
              zoomSmoothing={0.16}
              cameraSmoothing={0.8}
              showVision={false}
              showVisionCone={true}
              explanationMode="combined"
            />
          </div>
          <div class="pov-wash" aria-hidden="true"></div>

          <div class="pov-topbar mono-label">
            <span>05 / A boid's-eye view</span>
            <span class="pov-state">Flock</span>
            <span>Scroll to inspect ↓</span>
          </div>

          <div class="pov-copy-stack">
            <article class="pov-step is-active" data-pov-step="0">
              <span class="step-count mono-label">01 / 04</span>
              <h2 id="pov-title">The global pattern has a local cause.</h2>
              <p>
                From a distance, the flock reads as one organism. Move closer and that unity dissolves into agents with
                incomplete information.
              </p>
            </article>
            <article class="pov-step" data-pov-step="1" aria-hidden="true">
              <span class="step-count mono-label">02 / 04</span>
              <h2>A moving aperture is the whole world.</h2>
              <p>
                The blue sector is everything this boid can use right now. Anything behind it or beyond the radius gets
                no vote this frame.
              </p>
            </article>
            <article class="pov-step" data-pov-step="2" aria-hidden="true">
              <span class="step-count mono-label">03 / 04</span>
              <h2>Neighbors become measurements.</h2>
              <p>
                Each blue line identifies one usable neighbor. Its small green arrow contributes a heading; together,
                those headings become the larger alignment proposal. The evidence changes every frame.
              </p>
            </article>
            <article class="pov-step" data-pov-step="3" aria-hidden="true">
              <span class="step-count mono-label">04 / 04</span>
              <h2>Behavior is a weighted argument.</h2>
              <p>
                Red, green, and blue proposals are added, then speed and turn limits decide what is physically possible.
                Repeat that private calculation for every boid and the public flock appears.
              </p>
              <div class="step-legend" aria-label="Steering vector colors">
                <span><i class="signal signal--red"></i>Separation</span>
                <span><i class="signal signal--green"></i>Alignment</span>
                <span><i class="signal signal--blue"></i>Cohesion</span>
              </div>
            </article>
          </div>

          <ol class="pov-progress" aria-label="Boid's-eye sequence progress">
            <li class="is-active" data-pov-marker="0"><span>01</span><b>Flock</b></li>
            <li data-pov-marker="1"><span>02</span><b>Field</b></li>
            <li data-pov-marker="2"><span>03</span><b>Signals</b></li>
            <li data-pov-marker="3"><span>04</span><b>Steer</b></li>
          </ol>
          <div class="pov-progress-line" aria-hidden="true"><i></i></div>
        </div>
      </section>

      <section class="mixer-section" id="playground" aria-labelledby="mixer-title">
        <div class="story-shell">
          <div class="section-rail mono-label">
            <span>06</span>
            <span>Synthesis</span>
            <span>Live rule mixer</span>
          </div>

          <div class="mixer-heading">
            <h2 id="mixer-title">Tune your own flock.</h2>
            <div>
              <p class="lede">
                There are lots of ways to tune a flock. Change the weight of each proposal step and the same simple
                agents become a loose cloud, a directional school, or a nervous cluster.
              </p>
              <p>Move through the field to disturb it. The flock will follow you.</p>
            </div>
          </div>

          <div
            class="steering-equation"
            aria-label="The next velocity is the current velocity plus weighted separation, alignment, and cohesion vectors"
          >
            <span>velocity<sub>next</sub></span>
            <i>=</i>
            <span>velocity</span>
            <i>+</i>
            <span class="equation-red">s · separate</span>
            <i>+</i>
            <span class="equation-green">a · align</span>
            <i>+</i>
            <span class="equation-blue">c · cohere</span>
          </div>

          <div class="mixer-lab">
            <div class="mixer-controls">
              <div class="control-heading mono-label">
                <span>Rule weights / 0–100</span>
                <span>Drag to tune</span>
              </div>

              <label class="mixer-control mixer-control--red">
                <span><b>Separation</b><output data-mixer-output="separationFactor">30</output></span>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="30"
                  step="1"
                  aria-label="Separation weight"
                  data-mixer-control
                  data-param="separationFactor"
                  data-scale="0.0005"
                />
                <small>Push away from crowding</small>
              </label>

              <label class="mixer-control mixer-control--green">
                <span><b>Alignment</b><output data-mixer-output="alignmentFactor">24</output></span>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="24"
                  step="1"
                  aria-label="Alignment weight"
                  data-mixer-control
                  data-param="alignmentFactor"
                  data-scale="0.0015"
                />
                <small>Match nearby headings</small>
              </label>

              <label class="mixer-control mixer-control--blue">
                <span><b>Cohesion</b><output data-mixer-output="cohesionFactor">10</output></span>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="10"
                  step="1"
                  aria-label="Cohesion weight"
                  data-mixer-control
                  data-param="cohesionFactor"
                  data-scale="0.00012"
                />
                <small>Pull toward local centers</small>
              </label>

              <div class="preset-group" aria-label="Rule-weight presets">
                <span class="mono-label">Presets</span>
                <div>
                  <button class="is-active" type="button" data-mixer-preset="30,24,10">Balanced</button>
                  <button type="button" data-mixer-preset="16,66,8">Stream</button>
                  <button type="button" data-mixer-preset="12,14,42">Cluster</button>
                  <button type="button" data-mixer-preset="84,6,2">Scatter</button>
                </div>
              </div>

              <div class="lab-actions">
                <button type="button" data-mixer-pause aria-pressed="false">Pause motion</button>
                <button type="button" data-mixer-reset>Reseed flock</button>
              </div>
            </div>

            <div class="mixer-visual">
              <div class="mixer-canvas-meta mono-label">
                <span class="live-label"><i></i> Live synthesis</span>
                <span>Pointer influence / on</span>
              </div>
              <div class="mixer-canvas" aria-hidden="true">
                <BoidsCanvas
                  id="rule-mixer"
                  nBoids={900}
                  nBoidsMobile={190}
                  boidSize={9}
                  colorMode="velocity"
                  drawTrail={true}
                  trailLength={28}
                  cursorMagnetism={0.12}
                  cursorMagnetismRange={140}
                  enableFpsLimit={true}
                  showVision={false}
                />
              </div>
            </div>
          </div>
        </div>
      </section>

      <footer class="story-footer">
        <div class="story-shell">
          <p>Three local decisions.<br /><strong>One global illusion.</strong></p>
          <div>
            <a href="#top">Restart the story ↑</a>
            <a href="/">Back to index ↗</a>
          </div>
        </div>
      </footer>
    </main>

    <script>
      type ExplanationMode = "separation" | "alignment" | "cohesion" | "combined" | undefined;

      const getInstance = (id: string) => window.boidsInstances?.get(`${id}-container`);

      function closeMobileCodePanels(): void {
        if (!window.matchMedia("(max-width: 720px)").matches) return;
        document
          .querySelectorAll<HTMLDetailsElement>(".code-panel[open]")
          .forEach((panel) => panel.removeAttribute("open"));
      }

      function syncRuleZooms(): void {
        const demos = [
          { id: "rule-separation", range: 48, fraction: 0.36 },
          { id: "rule-alignment", range: 76, fraction: 0.36 },
          { id: "rule-cohesion", range: 76, fraction: 0.36 },
        ];

        for (const demo of demos) {
          const instance = getInstance(demo.id);
          const stage = document
            .querySelector<HTMLElement>(`#${demo.id}-container`)
            ?.closest<HTMLElement>(".visual-window");
          if (!instance || !stage) continue;
          const zoom = Math.max(1.55, Math.min(5, (stage.clientWidth * demo.fraction) / demo.range));
          instance.setParams({ zoomLevel: zoom });
        }
      }

      function initPovSequence(): void {
        const section = document.querySelector<HTMLElement>(".pov-section");
        const steps = Array.from(document.querySelectorAll<HTMLElement>("[data-pov-step]"));
        const markers = Array.from(document.querySelectorAll<HTMLElement>("[data-pov-marker]"));
        const state = document.querySelector<HTMLElement>(".pov-state");
        if (!section || steps.length === 0) return;

        const stateNames = ["Flock", "Field", "Signals", "Steer"];
        let frameRequested = false;
        let previousStep = -1;

        const update = (): void => {
          frameRequested = false;
          const rect = section.getBoundingClientRect();
          const travel = Math.max(1, section.offsetHeight - window.innerHeight);
          const progress = Math.max(0, Math.min(1, -rect.top / travel));
          const activeStep = Math.min(3, Math.floor(progress * 4));
          const isMobile = window.matchMedia("(max-width: 720px)").matches;
          const minZoom = isMobile ? 0.9 : 1;
          const maxZoom = isMobile ? 3.9 : 5.4;
          const zoomLevel = minZoom + (maxZoom - minZoom) * progress;
          const explanationMode: ExplanationMode =
            activeStep === 2 ? "alignment" : activeStep >= 3 ? "combined" : undefined;

          section.style.setProperty("--pov-progress", String(progress));
          section.dataset.stage = String(activeStep);

          const instance = getInstance("boids-eye-canvas");
          instance?.setParams({
            zoomLevel,
            showVision: activeStep >= 1,
            explanationMode,
          });

          if (activeStep === previousStep) return;
          previousStep = activeStep;
          state && (state.textContent = stateNames[activeStep]);
          steps.forEach((step, index) => {
            const active = index === activeStep;
            step.classList.toggle("is-active", active);
            step.setAttribute("aria-hidden", String(!active));
          });
          markers.forEach((marker, index) => marker.classList.toggle("is-active", index === activeStep));
        };

        const requestUpdate = (): void => {
          if (frameRequested) return;
          frameRequested = true;
          requestAnimationFrame(update);
        };

        window.addEventListener("scroll", requestUpdate, { passive: true });
        window.addEventListener("resize", requestUpdate, { passive: true });
        requestUpdate();
      }

      function initMixer(): void {
        const sliders = Array.from(document.querySelectorAll<HTMLInputElement>("[data-mixer-control]"));
        const presets = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-mixer-preset]"));
        const pauseButton = document.querySelector<HTMLButtonElement>("[data-mixer-pause]");
        const resetButton = document.querySelector<HTMLButtonElement>("[data-mixer-reset]");
        if (sliders.length === 0) return;

        const applyValues = (): void => {
          const params: Record<string, number> = {};
          for (const slider of sliders) {
            const param = slider.dataset.param;
            const scale = Number(slider.dataset.scale);
            if (!param || !Number.isFinite(scale)) continue;
            params[param] = Number(slider.value) * scale;
            const output = document.querySelector<HTMLOutputElement>(`[data-mixer-output="${param}"]`);
            if (output) output.value = slider.value.padStart(2, "0");
          }
          getInstance("rule-mixer")?.setParams(params);
        };

        sliders.forEach((slider) => {
          slider.addEventListener("input", () => {
            presets.forEach((preset) => preset.classList.remove("is-active"));
            applyValues();
          });
        });

        presets.forEach((preset) => {
          preset.addEventListener("click", () => {
            const values = preset.dataset.mixerPreset?.split(",") ?? [];
            sliders.forEach((slider, index) => {
              if (values[index] !== undefined) slider.value = values[index];
            });
            presets.forEach((button) => button.classList.toggle("is-active", button === preset));
            applyValues();
          });
        });

        pauseButton?.addEventListener("click", () => {
          const instance = getInstance("rule-mixer");
          if (!instance) return;
          instance.isPaused = !instance.isPaused;
          pauseButton.setAttribute("aria-pressed", String(instance.isPaused));
          pauseButton.textContent = instance.isPaused ? "Resume motion" : "Pause motion";
        });

        resetButton?.addEventListener("click", () => {
          const instance = getInstance("rule-mixer");
          if (!instance) return;
          instance.sim.init(instance.width, instance.height);
          instance.renderer.syncBuffers();
        });

        applyValues();
      }

      function initStory(): void {
        closeMobileCodePanels();
        initPovSequence();
        initMixer();
        requestAnimationFrame(syncRuleZooms);
        window.setTimeout(syncRuleZooms, 160);
        window.addEventListener("resize", syncRuleZooms, { passive: true });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initStory, { once: true });
      } else {
        initStory();
      }
    </script>
  </body>
</html>
