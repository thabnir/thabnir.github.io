      <!-- Full Experience -->
      <section class="full-experience" id="full-experience" data-section="full">
        <div class="playground-header">
          <span class="section-number">10 — Playground</span>
          <h2 class="section-title">Experiment</h2>
          <div class="playground-hint" id="playground-hint">
            <span
              >Click the menu in the corner to tweak boid simulation parameters.</span
            >
            <button class="hint-close" aria-label="Close hint"
              ><Icon name="material-symbols:close" /></button
            >
          </div>
        </div>
        <div class="full-boids-container">
          <BoidsCanvas
            id="full-boids"
            nBoids={700}
            boidSize={12}
            trailLength={35}
            drawTrail={true}
            colorMode="velocity"
            showVision={false}
            visionBoidIndex={0}
            showStats={false}
            showControls={true}
            maxSpeed={1.5}
            visualRange={60}
            wallMargin={50}
            followBoid={false}
            zoomLevel={1}
            cameraSmoothing={0.08}
            zoomSmoothing={0.02}
            cursorMagnetism={0.15}
            cursorMagnetismRange={350}
          />
        </div>
      </section>

      <script>
        import renderMathInElement from "katex/contrib/auto-render";

        const jumpLink = document.querySelector(".jump-link");
        const backgroundBoids = document.querySelector(
          ".boids-background",
        ) as HTMLElement | null;

        // Scroll-based updates
        function handleScroll() {
          const windowHeight = window.innerHeight;

          // Handle zoom section scroll
          const zoomSection = document.querySelector(
            '[data-section="boid-pov"]',
          );
          if (zoomSection) {
            const rect = zoomSection.getBoundingClientRect();
            const sectionHeight = rect.height;
            // Start zooming as soon as the section top reaches bottom of viewport
            // End zooming when section bottom reaches top of viewport
            const scrollIntoSection = windowHeight - rect.top;
            const totalScrollDistance = sectionHeight + windowHeight;
            const scrollProgress = Math.max(
              0,
              Math.min(1, scrollIntoSection / totalScrollDistance),
            );

            // Update zoom boids instance
            if (
              window.boidsInstances &&
              window.boidsInstances.has("demo-zoom-container")
            ) {
              const instance = window.boidsInstances.get("demo-zoom-container");
              if (instance) {
                // Use smaller zoom range on mobile for better proportions
                const isMobile = window.innerWidth <= 768;
                const minZoom = isMobile ? 0.6 : 1;
                const maxZoom = isMobile ? 3.5 : 6.5;
                const targetZoom =
                  minZoom + scrollProgress * (maxZoom - minZoom);
                instance.setParams({ zoomLevel: targetZoom });
              }
            }

            // Show/hide NYT-style scroll blurbs based on progress
            const blurb1 = document.getElementById("zoom-blurb-1");
            const blurb2 = document.getElementById("zoom-blurb-2");
            const blurb3 = document.getElementById("zoom-blurb-3");
            const blurb4 = document.getElementById("zoom-blurb-4");

            // Each blurb visible for a portion of the scroll
            const show = (el: HTMLElement | null, visible: boolean) => {
              if (el) el.classList.toggle("visible", visible);
            };

            show(blurb1, scrollProgress > 0.08 && scrollProgress < 0.35);
            show(blurb2, scrollProgress > 0.25 && scrollProgress < 0.5);
            show(blurb3, scrollProgress > 0.42 && scrollProgress < 0.7);
            show(blurb4, scrollProgress > 0.6 && scrollProgress < 0.88);
          }

          // Hide jump link after scrolling a bit
          const jumpLink = document.querySelector(".jump-link");
          if (jumpLink) {
            const scrollY = window.scrollY;
            if (scrollY > windowHeight * 0.25) {
              jumpLink.classList.add("is-hidden");
            } else {
              jumpLink.classList.remove("is-hidden");
            }
          }
        }

        window.addEventListener("scroll", handleScroll, { passive: true });

        // Initial call
        handleScroll();

        // Set mobile-appropriate zoom levels for fixed-zoom demos
        function setMobileZoomLevels() {
          const isMobile = window.innerWidth <= 768;

          // Separation demo (Personal Space) - reduce zoom on mobile
          if (
            window.boidsInstances &&
            window.boidsInstances.has("demo-separation-container")
          ) {
            const separationInstance = window.boidsInstances.get(
              "demo-separation-container",
            );
            if (separationInstance) {
              separationInstance.setParams({
                zoomLevel: isMobile ? 3.5 : 5.0,
              });
            }
          }

          // Playground - start more zoomed out on mobile
          if (
            window.boidsInstances &&
            window.boidsInstances.has("full-boids-container")
          ) {
            const playgroundInstance = window.boidsInstances.get(
              "full-boids-container",
            );
            if (playgroundInstance) {
              playgroundInstance.setParams({
                zoomLevel: isMobile ? 0.7 : 1.0,
              });
            }
          }
        }

        // Wait briefly for boids instances to initialize, then apply mobile zoom
        setTimeout(setMobileZoomLevels, 100);

        // Dismiss playground hint
        const hintClose = document.querySelector(".hint-close");
        const playgroundHint = document.getElementById("playground-hint");
        if (hintClose && playgroundHint) {
          hintClose.addEventListener("click", () => {
            playgroundHint.classList.add("hidden");
          });
        }

        // Hide the farthest-back background boids when any foreground boids canvases are visible.
        try {
          const bgId = "bg-boids-container";
          const foregroundCanvases = Array.from(
            document.querySelectorAll<HTMLElement>(
              `.boids-container:not(#${bgId})`,
            ),
          );

          if (backgroundBoids && foregroundCanvases.length > 0) {
            let visibleCount = 0;
            const updateBgVisibility = (): void => {
              backgroundBoids.classList.toggle("is-hidden", visibleCount > 0);
            };

            const io = new IntersectionObserver(
              (entries) => {
                for (const entry of entries) {
                  const wasVisible =
                    (entry.target as HTMLElement).dataset.bgHidesBg === "1";
                  // Treat even small “slivers” (e.g. ~100px of a 100vh canvas) as visible,
                  // otherwise the fixed background layer can show behind/around the canvas.
                  const isVisible =
                    entry.isIntersecting &&
                    (entry.intersectionRatio >= 0.02 ||
                      (entry.intersectionRect.height >= 16 &&
                        entry.intersectionRect.width >= 16));

                  if (!wasVisible && isVisible) {
                    (entry.target as HTMLElement).dataset.bgHidesBg = "1";
                    visibleCount++;
                  } else if (wasVisible && !isVisible) {
                    delete (entry.target as HTMLElement).dataset.bgHidesBg;
                    visibleCount = Math.max(0, visibleCount - 1);
                  }
                }
                updateBgVisibility();
              },
              {
                // Include low thresholds so we get callbacks as a canvas grows from
                // a tiny intersection into a visible slice.
                threshold: [0, 0.01, 0.02, 0.05, 0.1, 0.2, 0.3],
                rootMargin: "0px",
              },
            );

            foregroundCanvases.forEach((el) => io.observe(el));
          }
        } catch (err) {
          console.warn("Background boids visibility observer failed", err);
        }

        // KaTeX: render any $...$ / $$...$$ math in this page
        try {
          const root =
            document.querySelector(".content-wrapper") ?? document.body;
          renderMathInElement(root as HTMLElement, {
            delimiters: [
              { left: "$$", right: "$$", display: true },
              { left: "$", right: "$", display: false },
            ],
            throwOnError: false,
            ignoredClasses: ["code-block"],
          });
        } catch (err) {
          // Non-fatal: page still works without math rendering.
          console.warn("KaTeX auto-render failed", err);
        }

        // Full Experience zoom-out animation
        // When the section first becomes visible, smoothly zoom out and stop following
        try {
          const fullExperienceSection =
            document.getElementById("full-experience");
          let hasTriggeredZoomOut = false;
          let hasPrimedFullExperience = false;
          let zoomOutAnimationId: number | null = null;

          if (fullExperienceSection) {
            const fullExperienceObserver = new IntersectionObserver(
              (entries) => {
                for (const entry of entries) {
                  if (!entry.isIntersecting) continue;

                  // Prime the playground instance as soon as it starts intersecting,
                  // but keep the canvas hidden until the section is meaningfully in view.
                  const instance = window.boidsInstances?.get(
                    "full-boids-container",
                  );
                  if (instance && !hasPrimedFullExperience) {
                    hasPrimedFullExperience = true;

                    // Find the boid closest to the center of the canvas
                    const centerX = instance.width / 2;
                    const centerY = instance.height / 2;
                    let closestIndex = 0;
                    let closestDistance = Infinity;

                    for (let i = 0; i < instance.boids.length; i++) {
                      const boid = instance.boids[i];
                      const dx = boid.x - centerX;
                      const dy = boid.y - centerY;
                      const dist = dx * dx + dy * dy; // squared distance is fine for comparison
                      if (dist < closestDistance) {
                        closestDistance = dist;
                        closestIndex = i;
                      }
                    }

                    const targetBoid = instance.boids[closestIndex];
                    const startZoom = 5;

                    // Instantly position camera on the center boid (no smoothing)
                    instance.cameraX =
                      targetBoid.x - instance.width / (2 * startZoom);
                    instance.cameraY =
                      targetBoid.y - instance.height / (2 * startZoom);
                    instance.currentZoom = startZoom;
                    instance.targetZoom = startZoom;

                    // Enable follow mode and show vision at the primed zoom.
                    // (Canvas is still hidden via CSS until we add .is-active.)
                    instance.setParams({
                      visionBoidIndex: closestIndex,
                      followBoid: true,
                      showVision: true,
                      zoomLevel: startZoom,
                      cameraSmoothing: 0,
                    });
                  }

                  // Reveal once the section has a meaningful presence in the viewport.
                  // This prevents the “bottom edge peek” from showing a default state.
                  const revealNow =
                    entry.intersectionRect.height >= window.innerHeight * 0.25;
                  if (revealNow) {
                    fullExperienceSection.classList.add("is-active");
                  }

                  if (revealNow && !hasTriggeredZoomOut) {
                    hasTriggeredZoomOut = true;

                    // Start the zoom-out animation (if we have the instance).
                    if (instance) {
                      // Find the boid closest to the center of the canvas
                      const centerX = instance.width / 2;
                      const centerY = instance.height / 2;
                      let closestIndex = 0;
                      let closestDistance = Infinity;

                      for (let i = 0; i < instance.boids.length; i++) {
                        const boid = instance.boids[i];
                        const dx = boid.x - centerX;
                        const dy = boid.y - centerY;
                        const dist = dx * dx + dy * dy; // squared distance is fine for comparison
                        if (dist < closestDistance) {
                          closestDistance = dist;
                          closestIndex = i;
                        }
                      }

                      // Set up for the zoom-in then zoom-out animation
                      const targetBoid = instance.boids[closestIndex];
                      const startZoom = 5;
                      const endZoom = 1;

                      // Instantly position camera on the center boid (no smoothing)
                      instance.cameraX =
                        targetBoid.x - instance.width / (2 * startZoom);
                      instance.cameraY =
                        targetBoid.y - instance.height / (2 * startZoom);
                      instance.currentZoom = startZoom;
                      instance.targetZoom = startZoom;

                      // Now enable follow mode and show vision
                      instance.setParams({
                        visionBoidIndex: closestIndex,
                        followBoid: true,
                        showVision: true,
                        zoomLevel: startZoom,
                      });

                      const startTime = performance.now();
                      const duration = 2000; // 2 seconds for smooth transition

                      // Ease-out cubic function for smooth deceleration
                      const easeOutCubic = (t: number): number =>
                        1 - Math.pow(1 - t, 3);

                      const animateZoomOut = (currentTime: number): void => {
                        const elapsed = currentTime - startTime;
                        const progress = Math.min(elapsed / duration, 1);
                        const easedProgress = easeOutCubic(progress);

                        // Interpolate zoom level
                        const currentZoom =
                          startZoom + (endZoom - startZoom) * easedProgress;
                        instance.setParams({ zoomLevel: currentZoom });

                        if (progress < 1) {
                          zoomOutAnimationId =
                            requestAnimationFrame(animateZoomOut);
                        } else {
                          // Ensure final state is set
                          instance.setParams({
                            zoomLevel: 1,
                            followBoid: false,
                            showVision: false,
                            cameraSmoothing: 0.1,
                          });
                        }
                      };

                      zoomOutAnimationId =
                        requestAnimationFrame(animateZoomOut);
                    }
                  }
                }
              },
              {
                // Include low thresholds so we can prime early, and a mid threshold
                // so we can reveal/start the animation only when it feels intentional.
                threshold: [0, 0.05, 0.15, 0.25, 0.35],
                rootMargin: "0px",
              },
            );

            fullExperienceObserver.observe(fullExperienceSection);
          }
        } catch (err) {
          console.warn("Full experience zoom animation failed", err);
        }
      </script>
    </div>
  </body>
</html>
