---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Split posts: featured (first) and rest
const featuredPost = posts[0];
const remainingPosts = posts.slice(1);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ============================================
			   SWISS INTERNATIONAL STYLE - BLOG INDEX
			   ============================================ */

			main {
				width: 100%;
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 2rem 6rem;
			}

			/* Page Header */
			.page-header {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 4rem;
				padding: 4rem 0;
				border-bottom: 3px solid var(--text-heading);
				margin-bottom: 4rem;
			}

			.header-left {
				display: flex;
				flex-direction: column;
				justify-content: flex-end;
			}

			.accent-bar {
				width: 80px;
				height: 4px;
				background: var(--accent);
				margin-bottom: 1.5rem;
			}

			.page-title {
				font-size: clamp(3rem, 8vw, 6rem);
				font-weight: 700;
				line-height: 0.95;
				letter-spacing: -0.04em;
				margin: 0;
				color: var(--text-heading);
			}

			.header-right {
				display: flex;
				flex-direction: column;
				justify-content: flex-end;
			}

			.page-description {
				font-size: 1.25rem;
				line-height: 1.6;
				color: rgb(var(--gray));
				margin: 0;
				max-width: 400px;
			}

			.post-count {
				font-size: 0.75rem;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				color: var(--accent);
				font-weight: 600;
				margin-top: 1.5rem;
			}

			/* Featured Post */
			.featured-section {
				margin-bottom: 5rem;
			}

			.section-label {
				font-size: 0.75rem;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				font-weight: 600;
				margin-bottom: 1.5rem;
				display: flex;
				align-items: center;
				gap: 1rem;
			}

			.section-label::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgb(var(--gray-light));
			}

			.featured-post {
				display: grid;
				grid-template-columns: 1.2fr 1fr;
				gap: 3rem;
				text-decoration: none;
				color: inherit;
				transition: transform 0.3s ease;
			}

			.featured-post:hover {
				transform: translateY(-4px);
			}

			.featured-image {
				aspect-ratio: 16 / 10;
				overflow: hidden;
				background: rgb(var(--gray-light));
			}

			.featured-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.5s ease;
			}

			.featured-post:hover .featured-image img {
				transform: scale(1.02);
			}

			.featured-content {
				display: flex;
				flex-direction: column;
				justify-content: center;
				padding: 2rem 0;
			}

			.featured-meta {
				font-size: 0.75rem;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin-bottom: 1rem;
			}

			.featured-title {
				font-size: clamp(1.75rem, 3vw, 2.5rem);
				font-weight: 700;
				line-height: 1.15;
				letter-spacing: -0.02em;
				margin: 0 0 1rem;
				color: var(--text-heading);
				transition: color 0.2s ease;
			}

			.featured-post:hover .featured-title {
				color: var(--accent);
			}

			.featured-description {
				font-size: 1rem;
				line-height: 1.6;
				color: rgb(var(--gray));
				margin: 0;
			}

			.read-more {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				margin-top: 1.5rem;
				font-size: 0.875rem;
				font-weight: 600;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				color: var(--accent);
			}

			.read-more svg {
				width: 1rem;
				height: 1rem;
				transition: transform 0.2s ease;
			}

			.featured-post:hover .read-more svg {
				transform: translateX(4px);
			}

			/* Posts Grid */
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 3rem 2rem;
			}

			.post-card {
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
			}

			.post-card:hover .post-title {
				color: var(--accent);
			}

			.post-image {
				aspect-ratio: 16 / 10;
				overflow: hidden;
				background: rgb(var(--gray-light));
				margin-bottom: 1.25rem;
			}

			.post-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.4s ease;
			}

			.post-card:hover .post-image img {
				transform: scale(1.03);
			}

			.post-number {
				font-size: 0.75rem;
				font-weight: 700;
				color: var(--accent);
				margin-bottom: 0.5rem;
			}

			.post-meta {
				font-size: 0.75rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin-bottom: 0.5rem;
			}

			.post-title {
				font-size: 1.25rem;
				font-weight: 600;
				line-height: 1.3;
				letter-spacing: -0.01em;
				margin: 0;
				color: var(--text-heading);
				transition: color 0.2s ease;
			}

			/* No Posts State */
			.no-posts {
				text-align: center;
				padding: 4rem 2rem;
				color: rgb(var(--gray));
			}

			/* Responsive */
			@media (max-width: 1024px) {
				.posts-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 768px) {
				main {
					padding: 0 1rem 4rem;
				}

				.page-header {
					grid-template-columns: 1fr;
					gap: 2rem;
					padding: 2rem 0;
					margin-bottom: 3rem;
				}

				.featured-post {
					grid-template-columns: 1fr;
					gap: 1.5rem;
				}

				.featured-content {
					padding: 0;
				}

				.posts-grid {
					grid-template-columns: 1fr;
					gap: 2.5rem;
				}

				.section-label {
					margin-bottom: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<div class="header-left">
					<div class="accent-bar"></div>
					<h1 class="page-title">Blog</h1>
				</div>
				<div class="header-right">
					<p class="page-description">
						Thoughts on development, design, and the craft of building things for the web.
					</p>
					<p class="post-count">{posts.length} Articles</p>
				</div>
			</header>

			{posts.length === 0 ? (
				<p class="no-posts">No posts yet. Check back soon!</p>
			) : (
				<>
					{featuredPost && (
						<section class="featured-section">
							<p class="section-label">Featured</p>
							<a href={`/blog/${featuredPost.id}/`} class="featured-post">
								<div class="featured-image">
									{featuredPost.data.heroImage && (
										<Image
											width={800}
											height={500}
											src={featuredPost.data.heroImage}
											alt=""
										/>
									)}
								</div>
								<div class="featured-content">
									<p class="featured-meta">
										<FormattedDate date={featuredPost.data.pubDate} />
									</p>
									<h2 class="featured-title">{featuredPost.data.title}</h2>
									{featuredPost.data.description && (
										<p class="featured-description">{featuredPost.data.description}</p>
									)}
									<span class="read-more">
										Read Article
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M5 12h14M12 5l7 7-7 7"/>
										</svg>
									</span>
								</div>
							</a>
						</section>
					)}

					{remainingPosts.length > 0 && (
						<section>
							<p class="section-label">All Articles</p>
							<div class="posts-grid">
								{remainingPosts.map((post, index) => (
									<a href={`/blog/${post.id}/`} class="post-card">
										<div class="post-image">
											{post.data.heroImage && (
												<Image
													width={600}
													height={375}
													src={post.data.heroImage}
													alt=""
												/>
											)}
										</div>
										<span class="post-number">{String(index + 2).padStart(2, '0')}</span>
										<p class="post-meta">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h3 class="post-title">{post.data.title}</h3>
									</a>
								))}
							</div>
						</section>
					)}
				</>
			)}
		</main>
	</body>
</html>
